KMA_SERVICE_KEY=여기에_디코딩_서비스키_입력

KAKAO_REST_API_KEY=여기에_카카오_REST_API_키_입력

DB_HOST=localhost
DB_PORT=5432
DB_NAME=tancheon_risk
DB_USER=postgres
DB_PASSWORD=여기에_비밀번호_입력

TANCHEON_TARGET_POINT=midstream

TANCHEON_NX=62
TANCHEON_NY=123

DRY_DAY_THRESHOLD_MM=1.0

# CrewAI가 호출하는 LLM API 키. Google AI Studio(aistudio.google.com)에서 카드 등록 없이
# 무료로 발급 가능 (gemini-2.0-flash 무료 티어 사용, 분당/일일 요청 수 제한 있음).
GEMINI_API_KEY=여기에_Gemini_API_키_입력

# 담당 공무원 SMS 알림용 Solapi (대국민 긴급재난문자/CBS 아님 — 부서 내부 알림)
# solapi.com 가입(개인/비사업자 가능, 가입 시 무료 포인트 지급)
# → console.solapi.com > 발신번호 관리에서 본인 번호 등록(본인인증) → API Key 관리에서 키 발급
SOLAPI_API_KEY=여기에_Solapi_API_Key_입력
SOLAPI_API_SECRET=여기에_Solapi_API_Secret_입력
SOLAPI_FROM_NUMBER=여기에_등록한_발신번호_입력(010으로_시작,하이픈없이)
SOLAPI_TO_NUMBER=여기에_담당_공무원_번호_입력(010으로_시작,하이픈없이)
